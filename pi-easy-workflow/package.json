{
  "name": "@jmarceno/pi-easy-workflow",
  "version": "0.1.0",
  "description": "Review-driven workflow with kanban board for pi",
  "type": "module",
  "license": "MIT",
  "private": false,
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "workflow",
    "kanban",
    "review"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jmarceno/opencode-easy-workflow"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./src/skills"
    ],
    "prompts": [
      "./src/prompts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.52.7",
    "@mariozechner/pi-tui": ">=0.52.7"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-coding-agent": {
      "optional": true
    },
    "@mariozechner/pi-tui": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aliou/biome-plugins": "^0.3.0",
    "@aliou/pi-utils-settings": "^0.2.0",
    "@biomejs/biome": "^2.0.0",
    "@changesets/cli": "^2.27.0",
    "@mariozechner/pi-coding-agent": "0.52.7",
    "@mariozechner/pi-tui": "0.52.7",
    "@types/node": "^25.0.0",
    "husky": "^9.0.0",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "pi:install": "./scripts/pi-package.sh install",
    "pi:install:local": "./scripts/pi-package.sh install --local",
    "pi:remove": "./scripts/pi-package.sh remove",
    "pi:remove:local": "./scripts/pi-package.sh remove --local",
    "pi:update": "./scripts/pi-package.sh update",
    "pi:update:local": "./scripts/pi-package.sh update --local",
    "test:kanban-ui": "node tests/kanban-ui-smoke.mjs",
    "test:kanban-ui:extended": "node tests/kanban-ui-extended.mjs",
    "test:kanban-chain": "node tests/kanban-chain-e2e.mjs",
    "test:pi-runtime": "node tests/pi-runtime-smoke.mjs",
    "lint": "biome check",
    "format": "biome check --write",
    "check:lockfile": "pnpm install --frozen-lockfile --ignore-scripts",
    "prepare": "[ -d .git ] && husky || true",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm changeset publish"
  },
  "pnpm": {
    "overrides": {
      "@mariozechner/pi-ai": "$@mariozechner/pi-coding-agent",
      "@mariozechner/pi-tui": "$@mariozechner/pi-coding-agent"
    }
  },
  "packageManager": "pnpm@10.26.1",
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/ws": "^8.18.1",
    "better-sqlite3": "^12.8.0",
    "ws": "^8.20.0"
  }
}
